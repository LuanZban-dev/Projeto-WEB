generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model DraftPlayer {
  id          String      @id @default(uuid())
  externalId  String?     @unique
  name        String
  team        String?
  nationality String?
  position    String?
  birthDate   String?
  imageUrl    String?
  status      String   @default("WATCHLIST")
  draftRound  Int?
  draftPick   Int?
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}
